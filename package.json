    "./output/sqlite": "./src/output/sqlite.ts",
    "./output/sqlite-storage": "./src/output/sqlite-storage.ts",
    "./output/parquet": "./src/output/parquet.ts",
    "./output/storage": "./src/output/storage.ts",
    "./cursor": "./src/cursor.ts",
    "./verify": "./src/verify.ts",
